{
  "name": "gitbench",
  "productName": "GitBench",
  "version": "0.1.1",
  "description": "Worktree Diff Viewer — pick a repository, browse its Git worktrees, view the uncommitted diff of any worktree",
  "main": "./out/main/index.js",
  "private": true,
  "license": "MIT",
  "author": "Tugkan Pilka <tugkan@pilka.com.tr>",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dist": "electron-vite build && electron-builder --mac --publish never",
    "dist:unsigned": "electron-vite build && electron-builder --mac --publish never -c.mac.identity=null -c.mac.notarize=false -c.mac.hardenedRuntime=false"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "refractor": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/refractor": "^3.4.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  }
}
